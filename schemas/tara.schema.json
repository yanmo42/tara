{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/yanmo42/tara/blob/main/schemas/tara.schema.json",
  "title": "TemporalArcReferenceArray",
  "description": "Base TARA schema. A bounded structured record of what one temporal arc can hand to another.",
  "type": "object",
  "required": [
    "sourceArc",
    "targetArc",
    "timeMarker",
    "stateSummary",
    "confidence",
    "driftEstimate",
    "reconstructionTarget"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional schema self-reference for tooling"
    },
    "sourceArc": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "description": "Arc identifier" },
            "temporalBand": { "enum": ["fast", "meso", "slow"], "description": "Cadence band" },
            "cadenceHz": { "type": "number", "minimum": 0, "description": "Operating frequency" },
            "role": { "type": "string", "description": "Arc role (e.g. observer, chaser, branch, spine)" }
          },
          "additionalProperties": false
        }
      ],
      "description": "Identifier of the arc that emitted this array — string or structured object with temporal band and role"
    },
    "targetArc": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["id"],
          "properties": {
            "id": { "type": "string", "minLength": 1, "description": "Arc identifier" },
            "temporalBand": { "enum": ["fast", "meso", "slow"], "description": "Cadence band" },
            "cadenceHz": { "type": "number", "minimum": 0, "description": "Operating frequency" },
            "role": { "type": "string", "description": "Arc role (e.g. observer, chaser, branch, spine)" }
          },
          "additionalProperties": false
        }
      ],
      "description": "Identifier of the arc that will consume this array — string or structured object with temporal band and role"
    },
    "timeMarker": {
      "type": "string",
      "minLength": 1,
      "description": "Timestamp or tick at which this array was emitted"
    },
    "stateSummary": {
      "type": "object",
      "additionalProperties": true,
      "description": "Compressed representation of source-arc state at emission time"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "How much the target arc should trust this representation"
    },
    "driftEstimate": {
      "oneOf": [
        { "type": "number", "minimum": 0 },
        {
          "type": "object",
          "required": ["overall"],
          "properties": {
            "overall": { "type": "number", "minimum": 0, "description": "Aggregate drift rate" },
            "perField": {
              "type": "object",
              "additionalProperties": { "type": "number", "minimum": 0 },
              "description": "Per-field drift rates (e.g. position drifts faster than identity)"
            },
            "decayModel": {
              "enum": ["exponential", "linear", "step"],
              "description": "How confidence decays as the array ages"
            }
          },
          "additionalProperties": false
        }
      ],
      "description": "Expected rate of staleness — single number or structured per-field breakdown with decay model"
    },
    "reconstructionTarget": {
      "type": "string",
      "minLength": 1,
      "description": "What the target arc is trying to recover from this array"
    },
    "lossNotes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Explicit record of what was dropped or compressed away"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "description": "Origin metadata: emitter, method, version"
    },
    "trustClass": {
      "type": "string",
      "enum": ["self", "neighbor", "external", "synthetic"],
      "description": "Relationship between emitter and consumer"
    },
    "validityWindow": {
      "type": "object",
      "description": "Duration after which this array should be treated as stale",
      "properties": {
        "ticks": { "type": "integer", "minimum": 1, "description": "Validity in tick-count" },
        "duration": { "type": "string", "description": "Validity as ISO 8601 duration or human-readable" }
      },
      "minProperties": 1,
      "additionalProperties": false
    }
  }
}
